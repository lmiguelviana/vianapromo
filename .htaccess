Options -Indexes
RewriteEngine On
RewriteBase /viana/

# Arquivos e diretórios físicos passam direto
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rotas limpas (com ou sem barra final)
RewriteRule ^/?$             index.php     [L]
RewriteRule ^grupos/?$       grupos.php    [L]
RewriteRule ^historico/?$    historico.php [L]
RewriteRule ^usuarios/?$     usuarios.php  [L]
RewriteRule ^config/?$       config.php    [L]
RewriteRule ^perfil/?$       perfil.php    [L]
RewriteRule ^logs/?$         logs.php      [L]
RewriteRule ^login/?$        login.php     [L]
RewriteRule ^logout/?$       logout.php    [L]
RewriteRule ^fila/?$         fila.php      [L]
