Options -Indexes
ErrorDocument 404 /viana/404.php

# ── Bloquear acesso direto a diretórios sensíveis ────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(cron|bot|database|storage|app)/ - [F,L]
</IfModule>

# ── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

RewriteEngine On
RewriteBase /viana/

# Rota raiz deve vir antes do check de diretório (evita Apache servir index.php como DirectoryIndex)
RewriteRule ^/?$             portal.php    [L]

# Arquivos e diretórios físicos passam direto
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^v-admin/?$      index.php     [L]
RewriteRule ^grupos/?$       grupos.php    [L]
RewriteRule ^historico/?$    historico.php [L]
RewriteRule ^usuarios/?$     usuarios.php  [L]
RewriteRule ^config/?$       config.php    [L]
RewriteRule ^perfil/?$       perfil.php    [L]
RewriteRule ^logs/?$         logs.php      [L]
RewriteRule ^login/?$        login.php     [L]
RewriteRule ^logout/?$       logout.php    [L]
RewriteRule ^fila/?$         fila.php      [L]
RewriteRule ^portal/?$       portal.php    [L]
RewriteRule ^slides/?$       slides.php    [L]
